<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="com.sky.mapper.DishMapper">
    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        insert into sky_take_out.dish (name,category_id,price,image,description,status,create_time,update_time,create_user,update_user)
        values (#{name},#{categoryId},#{price},#{image},#{description},#{status},#{createTime},#{updateTime},#{createUser},#{updateUser})
    </insert>

    <!-- 修改菜品信息 -->
    <update id="update">
        update sky_take_out.dish
        <set>
            <if test="name != null">name = #{name},</if>
            <if test="categoryId != null">category_id = #{categoryId},</if>
            <if test="price != null">price = #{price},</if>
            <if test="image != null">image = #{image},</if>
            <if test="description != null">description = #{description},</if>
            <if test="status != null">status = #{status},</if>
        </set>
         where  id = #{id}
    </update>



    <delete id="delete">
delete  from dish where id in
                  <foreach collection="ids" item="id" separator="," open="(" close=")">
                    #{id}
                </foreach>
    </delete>
    <select id="pageQuery" resultType="com.sky.entity.Dish">
        select d.*,c.name as category_name from dish d  left join  category c on d.category_id = c.id
        <where>
            <if test="name != null and name != ''">
                and d.name like concat(concat('%',#{name}),'%')
            </if>
            <if test="categoryId != null">
                and d.category_id = #{categoryId}
            </if>
            <if test="status != null">
                and d.status = #{status}
            </if>
        </where>
        order by d.update_time desc
    </select>


</mapper>